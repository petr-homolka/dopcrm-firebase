rules_version = '2';

// ============================================================
// Firestore Security Rules — Doprovázení CRM
//
// Sekce A (níže) = PŮVODNÍ generický prototyp (tenants/{tenantId}/data_objects
// + user_roles/{uid}, role: superadmin/vedeni/ko/asistent/pestoun/dite/externista).
// Ponecháno funkční kvůli zpětné kompatibilitě starších modulů (Kalendář,
// Dokumenty, Reporty, Workflow…), které na tomto modelu zatím stojí.
//
// Sekce B (níže) = NOVÉ explicitní B2B SaaS multi-tenant schéma
// (2026-07-01, zadání "SaaS hierarchie"), které nahrazuje user_roles/data_objects
// jako zdroj pravdy pro identitu/hierarchii organizace → zaměstnanci → pěstouni →
// děti. Nové přihlašování a role-based dashboardy (SuperAdmin/OrgAdmin/Klíčová
// osoba) čtou VÝHRADNĚ ze sekce B. Cíl V8: sekce B se stává jediným modelem,
// sekce A se postupně vyřadí.
//
// ROLE MODEL (sekce B), dokument users/{uid}:
//   {
//     email: string,
//     displayName: string,
//     role: "superadmin" | "org_admin" | "klicova_osoba",
//     organizationId: string | null,   // null jen pro superadmina (cross-tenant)
//     department: "management" | "service" | "terenni" | null,
//     active: boolean,
//     createdAt, createdBy, updatedAt
//   }
//
// HIERARCHIE:
//   organizations/{orgId}                       — tenant (platící zákazník)
//   users/{uid}                                  — zaměstnanci (žádní pěstouni/děti!)
//   foster_families/{familyId}                   — klientské rodiny (NEJSOU Auth uživatelé)
//     .organizationId, .assignedTo (uid klíčové osoby)
//   children/{childId}                           — děti svěřené do péče
//     .organizationId, .fosterFamilyId, .assignedTo (denormalizováno z rodiny)
//
// BEZPEČNÝ MODEL PRO "KLÍČOVOU OSOBU":
//   - čtení: všechny foster_families/children VE SVÉ organizaci (potřebuje
//     přehled o kolezích, zastupitelnost při nemoci apod.)
//   - zápis (update/delete): jen záznamy, kde assignedTo == její uid
//   - založení nové rodiny (create): NE — jen org_admin/superadmin (přiřazení
//     řeší management), klíčová osoba může jen navrhnout přes org_admina.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════
    // SEKCE B — NOVÉ B2B SaaS schéma (2026-07-01)
    // ════════════════════════════════════════════════════════

    function signedIn() {
      return request.auth != null;
    }

    // Profil VOLAJÍCÍHO uživatele z users/{uid} — jediný zdroj pravdy o roli.
    // (Custom Claims se nepoužívají, viz auth.js — konzistentní s ROLE_MODEL sekce A.)
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return signedIn() ? myProfile().role : null;
    }

    function myOrgId() {
      return signedIn() ? myProfile().organizationId : null;
    }

    function isSuperadmin() {
      return signedIn() && myRole() == 'superadmin';
    }

    function isOrgAdmin() {
      return signedIn() && myRole() == 'org_admin';
    }

    function isKlicovaOsoba() {
      return signedIn() && myRole() == 'klicova_osoba';
    }

    // Management organizace = smí zakládat/spravovat zaměstnance a rodiny v rámci
    // celé organizace (na rozdíl od klíčové osoby, která má jen svoje přidělené).
    // Přidáno 2026-07-02 s rozšířenou hierarchií (viz users/{uid} níže).
    function isManagement() {
      return signedIn() && myRole() in ['org_admin', 'vedouci_pobocky', 'teamleader'];
    }

    function sameOrg(orgId) {
      return signedIn() && myOrgId() == orgId;
    }

    // ── Role pěstouna (2026-07-06, docs/domain/chat-a-pestounska-appka.md) ──
    // KRITICKÉ: pěstoun má organizationId = svou organizaci, takže by přes
    // holé sameOrg() viděl VŠECHNY rodiny a děti organizace. Proto se sameOrg
    // větev u rodin/dětí/uživatelů/zpráv OMEZUJE na zaměstnance (isStaff) a
    // pěstoun dostává jen úzký disjunkt přes foster_families.fosterUserIds.
    function isStaff() {
      return signedIn() && myRole() in
        ['superadmin', 'org_admin', 'vedouci_pobocky', 'teamleader', 'klicova_osoba', 'asistent_ko', 'zamestnanec'];
    }

    function isFoster() {
      return signedIn() && myRole() == 'pestoun';
    }

    // Smí tento pěstoun vidět tuto rodinu? (uid je v jejím fosterUserIds)
    function fosterOfFamilyData(famData) {
      return isFoster() && (request.auth.uid in famData.get('fosterUserIds', []));
    }

    function fosterOfFamilyId(famId) {
      return fosterOfFamilyData(get(/databases/$(database)/documents/foster_families/$(famId)).data);
    }

    // ── organizations (tenanti) ──────────────────────────────
    // SaaS je SEBEOBSLUŽNÉ (2026-07-02): kdokoli přihlášený smí založit VLASTNÍ
    // organizaci (createdBy == on sám) — Superadmin organizace nezakládá, jen
    // spravuje/dohlíží. Update org. metadat smí zástupce organizace (org_admin),
    // ale ne měnit vlastní status/plán předplatného (to řídí jen Superadmin —
    // brání si sám sobě "upgradovat" tarif bez placení).
    match /organizations/{orgId} {
      allow read:  if isSuperadmin() || sameOrg(orgId);
      allow create: if isSuperadmin()
                       || (signedIn() && request.resource.data.createdBy == request.auth.uid);
      allow update: if isSuperadmin()
                       || (isOrgAdmin() && sameOrg(orgId)
                           && request.resource.data.status == resource.data.status
                           && request.resource.data.plan == resource.data.plan);
      allow delete: if isSuperadmin();

      // Pobočky organizace (volitelné — malá organizace nemusí mít žádnou).
      match /branches/{branchId} {
        allow read:  if isSuperadmin() || sameOrg(orgId);
        allow write: if isSuperadmin() || (isOrgAdmin() && sameOrg(orgId));
      }

      // Kalendářní události (audit nálezu #5, 2026-07-03 — Kalendář přepojen na
      // Sekci B). Čtení: kdokoli ze stejné organizace (přehled napříč týmem,
      // stejně jako u foster_families). Zápis: management celé organizace vždy;
      // klíčová osoba jen u vlastních událostí (assignedTo == její uid).
      match /events/{eventId} {
        allow read: if isSuperadmin() || sameOrg(orgId);
        allow create: if isSuperadmin()
          || (isManagement() && sameOrg(orgId))
          || (isKlicovaOsoba() && sameOrg(orgId) && request.resource.data.assignedTo == request.auth.uid);
        allow update, delete: if isSuperadmin()
          || (isManagement() && sameOrg(orgId))
          || (isKlicovaOsoba() && sameOrg(orgId) && resource.data.assignedTo == request.auth.uid);
      }

      // Číselníky organizace (2026-07-06, Lidl v4 bod 3 — vlastní typy
      // událostí apod.). Čtení: celá organizace (selecty). Zápis: management
      // — položky číselníků definuje administrace, ne terén.
      match /codelists/{listId} {
        allow read: if isSuperadmin() || sameOrg(orgId);
        allow write: if isSuperadmin() || (isManagement() && sameOrg(orgId));
      }
    }

    // ── org_slugs (rezervace unikátní adresy organizace) ─────────
    // Krok 1 (2026-07-03): top-level kolekce, doc ID == slug samotný. Slouží jen
    // jako "zámek" pro unikátnost — Firestore vyhodnotí zápis na EXISTUJÍCÍ doc
    // jako `update` (ne `create`), takže `allow update: if false` fakticky brání
    // komukoli slug "ukrást", i bez transakce na klientovi. Čtení je veřejné,
    // protože slug se má stát veřejnou URL (`doprovazeni.com/{slug}`, viz
    // INVENTAR.md "Veřejný profil organizace") a dostupnost se ověřuje ještě
    // před přihlášením/registrací.
    match /org_slugs/{slug} {
      allow read: if true;
      allow create: if slug.matches('^[a-z0-9]+(-[a-z0-9]+)*$')
                       && request.resource.data.organizationId is string
                       && (isSuperadmin()
                           || (isOrgAdmin() && myOrgId() == request.resource.data.organizationId));
      allow update: if false;
      allow delete: if isSuperadmin()
                       || (isOrgAdmin() && myOrgId() == resource.data.organizationId);
    }

    // ── users (zaměstnanci) ───────────────────────────────────
    // Role (hierarchie 2026-07-02, viz zadání): org_admin (zástupce/ředitel) →
    // vedouci_pobocky → teamleader → klicova_osoba → asistent_ko; + zamestnanec
    // (podpůrný personál bez řídicí role — sekretářka, ekonomka…).
    // Pěstouni a děti NEJSOU v této kolekci (nemají Auth účet v MVP).
    match /users/{uid} {
      // Čtení: superadmin vše; kdokoli přihlášený vidí SVŮJ profil; a kdokoli ze
      // STEJNÉ organizace vidí celý zaměstnanecký rozpis (2026-07-02 — dřív jen
      // org_admin, ale i klíčová osoba potřebuje vidět kolegy kvůli přiřazování
      // rodin a zastupitelnosti; navíc to opravuje Firestore "list" dotaz, který
      // jinak vždy spadne na permission-denied bez rovnostního filtru, jenž by
      // odpovídal pravidlu).
      // Pozor: sameOrg omezeno na zaměstnance — pěstoun čte JEN svůj profil
      // (jinak by viděl celý zaměstnanecký rozpis organizace).
      allow read: if isSuperadmin()
                     || request.auth.uid == uid
                     || (isStaff() && sameOrg(resource.data.organizationId));

      // Založení zaměstnance:
      //   superadmin      -> kohokoli, kdekoli
      //   SEBEREGISTRACE  -> uid == volající, role=org_admin, JEN pro organizaci,
      //                      kterou právě sám založil (createdBy na organizaci)
      //   org_admin       -> jakéhokoli zaměstnance VLASTNÍ organizace
      allow create: if isSuperadmin()
                       || (signedIn() && request.auth.uid == uid
                           && request.resource.data.role == 'org_admin'
                           && get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.createdBy == request.auth.uid)
                       || (isOrgAdmin()
                           && request.resource.data.organizationId == myOrgId()
                           && request.resource.data.role in ['org_admin', 'vedouci_pobocky', 'teamleader', 'klicova_osoba', 'asistent_ko', 'zamestnanec'])
                       // Pozvání pěstouna (inviteFoster) — KO i management smí založit
                       // účet role 'pestoun' ve VLASTNÍ organizaci (2026-07-06).
                       || ((isManagement() || isKlicovaOsoba())
                           && request.resource.data.organizationId == myOrgId()
                           && request.resource.data.role == 'pestoun');

      // Úprava: superadmin cokoli; org_admin své zaměstnance (nesmí je povýšit na
      // superadmina ani přehodit do jiné organizace); uživatel sám smí upravit
      // jen svůj profil (displayName) — role/organizationId řeší jen výš postavení.
      allow update: if isSuperadmin()
                       || (isOrgAdmin()
                           && sameOrg(resource.data.organizationId)
                           && resource.data.role != 'superadmin'
                           && request.resource.data.role != 'superadmin'
                           && request.resource.data.organizationId == resource.data.organizationId)
                       || (request.auth.uid == uid
                           && request.resource.data.role == resource.data.role
                           && request.resource.data.organizationId == resource.data.organizationId);

      allow delete: if isSuperadmin()
                       || (isOrgAdmin() && sameOrg(resource.data.organizationId) && resource.data.role != 'superadmin');

      // Notifikační centrum (2026-07-06, docs/domain/chat-a-pestounska-appka.md).
      // Čte/označuje/maže JEN vlastník. Zakládat smí jiný přihlášený uživatel ze
      // STEJNÉ organizace jako příjemce (KO notifikuje pěstouna a naopak) —
      // organizace příjemce se ověří get() na jeho users/{uid} dokument.
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth.uid == uid;
        allow create: if signedIn() && (
          request.auth.uid == uid
          || myOrgId() == get(/databases/$(database)/documents/users/$(uid)).data.organizationId
        );
      }
    }

    // ── foster_families (klientské rodiny) ───────────────────
    match /foster_families/{familyId} {
      // Čtení: superadmin vše; kdokoli ze STEJNÉ organizace (management i klíčová
      // osoba vidí i rodiny kolegů — potřeba přehledu/zastupitelnosti). Třetí
      // disjunkt (assignedTo) není jen zástupný — bez něj Firestore odmítne CELÝ
      // "list" dotaz filtrovaný přes `where('assignedTo', '==', uid)` (klíčová
      // osoba, "Moje rodiny"), protože se rovnostní pole dotazu neshoduje s
      // polem v pravidle (organizationId) — objeveno 2026-07-02.
      allow read: if isSuperadmin()
                     || (isStaff() && sameOrg(resource.data.organizationId))
                     || resource.data.assignedTo == request.auth.uid
                     || fosterOfFamilyData(resource.data);

      // Založení nové rodiny: management organizace kdekoli v ní; klíčová osoba
      // jen rovnou jako přidělenou sobě (terénní realita — potká rodinu, založí ji).
      allow create: if isSuperadmin()
                       || (isManagement() && sameOrg(request.resource.data.organizationId))
                       || (isKlicovaOsoba()
                           && sameOrg(request.resource.data.organizationId)
                           && request.resource.data.assignedTo == request.auth.uid);

      // Úprava/mazání: management organizace VŽDY;
      // klíčová osoba JEN u rodin, které má přímo přidělené (assignedTo == její uid).
      allow update, delete: if isSuperadmin()
                                || (isManagement() && sameOrg(resource.data.organizationId))
                                || (isKlicovaOsoba()
                                    && sameOrg(resource.data.organizationId)
                                    && resource.data.assignedTo == request.auth.uid);

      // Respit (odlehčovací volno) — historie čerpání per rodina/dohoda (2026-07-02).
      // Append-heavy log, proto subkolekce místo pole na rodičovském dokumentu.
      match /respitEvents/{eventId} {
        function parentFamily() {
          return get(/databases/$(database)/documents/foster_families/$(familyId)).data;
        }
        allow read: if isSuperadmin() || sameOrg(parentFamily().organizationId);
        allow create, update, delete: if isSuperadmin()
          || (isManagement() && sameOrg(parentFamily().organizationId))
          || (isKlicovaOsoba() && sameOrg(parentFamily().organizationId)
              && parentFamily().assignedTo == request.auth.uid);
      }

      // Vzdělávání pěstounů (kurzy) — append-only, roste v čase (audit nálezu
      // #4, 2026-07-03: dřív pole fosters[].courses[] vnořené v poli, teď
      // podkolekce s `personId` odkazem na konkrétní osobu ve `fosters[]`).
      match /fosterCourses/{courseId} {
        function parentFamilyCourses() {
          return get(/databases/$(database)/documents/foster_families/$(familyId)).data;
        }
        allow read: if isSuperadmin() || sameOrg(parentFamilyCourses().organizationId);
        allow create: if isSuperadmin()
          || (isManagement() && sameOrg(parentFamilyCourses().organizationId))
          || (isKlicovaOsoba() && sameOrg(parentFamilyCourses().organizationId)
              && parentFamilyCourses().assignedTo == request.auth.uid);
        allow update, delete: if false;
      }

      // Timeline (docs/domain/timeline.md, 2026-07-03) — chronologický deník
      // rodiny, důkazní hodnota. PRAVIDLO IMMUTABILITY POZASTAVENO 2026-07-05
      // na žádost produktového vlastníka (do odvolání) — zápis v terénu
      // vzniká po částech a musí se dát upravit, dokud se nedomluví
      // pravidla per typ záznamu (docs/INVENTAR.md). Update teď smí i
      // obsahová pole (`body`/`title`/`occurredAt`/`subjectRefs`), ne jen
      // `pinned` — `type`/`source`/`correctsEntryId`/`createdBy`/`createdAt`
      // (provenience záznamu) se stále NESMÍ měnit. Delete nikdy. Zápis/pin:
      // jen přiřazená KO nebo org_admin téže organizace — superadmin NE
      // (nepracuje s klientskými daty rodin, jen se systémem). Čtení:
      // superadmin vždy; jinak stejně jako u foster_families/children —
      // sameOrg (vč. nadřízených a kolegů KO kvůli přehledu/zastupitelnosti)
      // nebo přímo přiřazená KO.
      match /timeline/{entryId} {
        function parentFamilyTimeline() {
          return get(/databases/$(database)/documents/foster_families/$(familyId)).data;
        }
        function canWriteTimeline() {
          return (isOrgAdmin() && sameOrg(parentFamilyTimeline().organizationId))
              || (isKlicovaOsoba() && parentFamilyTimeline().assignedTo == request.auth.uid);
        }
        allow read: if isSuperadmin()
                       || sameOrg(parentFamilyTimeline().organizationId)
                       || parentFamilyTimeline().assignedTo == request.auth.uid;
        allow create: if canWriteTimeline();
        allow update: if canWriteTimeline()
                         && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['pinned', 'body', 'title', 'occurredAt', 'subjectRefs', 'updatedAt', 'updatedBy']);
        allow delete: if false;
      }

      // Chat rodiny — tři úrovně soukromí (2026-07-06,
      // docs/domain/chat-a-pestounska-appka.md). HRANICE JE TADY, ne v UI.
      //   private  — čte JEN autor (poznámka KO sobě)
      //   internal — čtou zaměstnanci organizace; pěstoun NIKDY
      //   foster   — čtou zaměstnanci I pěstoun rodiny (KO ↔ pěstoun)
      match /messages/{msgId} {
        function famData() {
          return get(/databases/$(database)/documents/foster_families/$(familyId)).data;
        }
        function staffCanPost() {
          return (isManagement() && sameOrg(famData().organizationId))
              || (isKlicovaOsoba() && famData().assignedTo == request.auth.uid);
        }
        allow read: if isSuperadmin()
          || (isStaff() && sameOrg(famData().organizationId)
              && resource.data.audience in ['internal', 'foster'])
          || (resource.data.audience == 'private' && resource.data.authorUid == request.auth.uid)
          || (resource.data.audience == 'foster' && fosterOfFamilyData(famData()));
        // Zaměstnanec smí libovolnou úroveň; pěstoun JEN 'foster' a jen do své
        // rodiny (jednosměrně KO). authorUid musí být volající (bez podvržení).
        allow create: if request.resource.data.authorUid == request.auth.uid && (
          staffCanPost()
          || (fosterOfFamilyData(famData()) && request.resource.data.audience == 'foster')
        );
        // Úprava/smazání jen vlastní zprávy.
        allow update, delete: if resource.data.authorUid == request.auth.uid;
      }
    }

    // ── children (děti svěřené do péče) ──────────────────────
    // organizationId + assignedTo jsou denormalizované z rodičovské foster_family
    // (viz orgService.js) — umožňuje stejná pravidla bez cross-collection get().
    match /children/{childId} {
      // Viz shodná poznámka u foster_families — assignedTo disjunkt kvůli
      // Firestore "list" dotazům filtrovaným přes assignedTo (budoucí použití).
      // sameOrg omezeno na zaměstnance; pěstoun vidí jen děti SVÉ rodiny
      // (přes fosterUserIds rodiny) — ne všechny děti organizace.
      allow read: if isSuperadmin()
                     || (isStaff() && sameOrg(resource.data.organizationId))
                     || resource.data.assignedTo == request.auth.uid
                     || fosterOfFamilyId(resource.data.fosterFamilyId);

      allow create: if isSuperadmin()
                       || (isManagement() && sameOrg(request.resource.data.organizationId))
                       || (isKlicovaOsoba()
                           && sameOrg(request.resource.data.organizationId)
                           && request.resource.data.assignedTo == request.auth.uid);

      allow update, delete: if isSuperadmin()
                                || (isManagement() && sameOrg(resource.data.organizationId))
                                || (isKlicovaOsoba()
                                    && sameOrg(resource.data.organizationId)
                                    && resource.data.assignedTo == request.auth.uid);

      // Historie změn dítěte ("nic se nepřepisuje", port z vanilla App.histAdd) —
      // append-only: založit smí kdokoli s právem k dítěti, upravit/smazat NIKDO.
      match /history/{historyId} {
        function parentChild() {
          return get(/databases/$(database)/documents/children/$(childId)).data;
        }
        allow read: if isSuperadmin() || sameOrg(parentChild().organizationId);
        allow create: if isSuperadmin()
          || (isManagement() && sameOrg(parentChild().organizationId))
          || (isKlicovaOsoba() && sameOrg(parentChild().organizationId)
              && parentChild().assignedTo == request.auth.uid);
        allow update, delete: if false;
      }

      // Trvalé poznámky KO — append-only, citlivý obsah s důkazní hodnotou
      // (audit nálezu #1, 2026-07-03: dřív pole na dokumentu, teď podkolekce
      // stejně jako `history` výše — "roste v čase" = vždy podkolekce).
      match /permanentNotes/{noteId} {
        function parentChildNotes() {
          return get(/databases/$(database)/documents/children/$(childId)).data;
        }
        allow read: if isSuperadmin() || sameOrg(parentChildNotes().organizationId);
        allow create: if isSuperadmin()
          || (isManagement() && sameOrg(parentChildNotes().organizationId))
          || (isKlicovaOsoba() && sameOrg(parentChildNotes().organizationId)
              && parentChildNotes().assignedTo == request.auth.uid);
        allow update, delete: if false;
      }

      // Předchozí pěstounské rodiny dítěte — append-only historie umístění
      // (audit nálezu #2, 2026-07-03: dřív pole na dokumentu, teď podkolekce).
      match /previousFosters/{entryId} {
        function parentChildPrevFosters() {
          return get(/databases/$(database)/documents/children/$(childId)).data;
        }
        allow read: if isSuperadmin() || sameOrg(parentChildPrevFosters().organizationId);
        allow create: if isSuperadmin()
          || (isManagement() && sameOrg(parentChildPrevFosters().organizationId))
          || (isKlicovaOsoba() && sameOrg(parentChildPrevFosters().organizationId)
              && parentChildPrevFosters().assignedTo == request.auth.uid);
        allow update, delete: if false;
      }

      // Rozsudky/usnesení soudního spisu dítěte — append-only (audit nálezu #3,
      // 2026-07-03: dřív pole courtCase.rozsudky[] na dokumentu, teď podkolekce).
      match /courtVerdicts/{verdictId} {
        function parentChildVerdicts() {
          return get(/databases/$(database)/documents/children/$(childId)).data;
        }
        allow read: if isSuperadmin() || sameOrg(parentChildVerdicts().organizationId);
        allow create: if isSuperadmin()
          || (isManagement() && sameOrg(parentChildVerdicts().organizationId))
          || (isKlicovaOsoba() && sameOrg(parentChildVerdicts().organizationId)
              && parentChildVerdicts().assignedTo == request.auth.uid);
        allow update, delete: if false;
      }
    }

    // ════════════════════════════════════════════════════════
    // SEKCE A — PŮVODNÍ generický prototyp (zachováno, legacy)
    // ════════════════════════════════════════════════════════

    // Čtení role z Firestore — NIKDY z custom claims (legacy model)
    function userRole() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data;
    }

    function hasRole(roleKey) {
      return isAuthenticatedLegacy() && userRole().role == roleKey;
    }

    function hasCap(cap) {
      return isAuthenticatedLegacy() && cap in userRole().caps;
    }

    function isSameTenant(tenantId) {
      return isAuthenticatedLegacy() && userRole().tenantId == tenantId;
    }

    function isSuperadminLegacy() {
      return hasRole('superadmin');
    }

    function isAuthenticatedLegacy() {
      return request.auth != null;
    }

    // user_roles: číst smí jen vlastník nebo superadmin; psát jen superadmin/vedení
    match /user_roles/{uid} {
      allow read: if isAuthenticatedLegacy() && (request.auth.uid == uid || isSuperadminLegacy());
      allow write: if isSuperadminLegacy() || hasRole('vedeni');
    }

    // ROOT kolekce data_objects — ZAKÁZÁNA (data musí být v tenants/{tenantId}/data_objects)
    match /data_objects/{docId} {
      allow read, write: if false;
    }

    match /tenants/{tenantId} {

      allow read:  if isSameTenant(tenantId) || isSuperadminLegacy();
      allow write: if isSuperadminLegacy() || (hasRole('vedeni') && isSameTenant(tenantId));

      match /data_objects/{docId} {
        allow read, write: if isSuperadminLegacy();
        allow read, write: if hasRole('vedeni') && isSameTenant(tenantId);
        allow read:  if hasRole('ko') && isSameTenant(tenantId);
        allow write: if hasRole('ko') && isSameTenant(tenantId) && hasCap('contacts.edit');
        allow read:  if hasRole('asistent') && isSameTenant(tenantId);
        allow write: if hasRole('asistent') && isSameTenant(tenantId)
                        && (hasCap('notes.add') || hasCap('docs.upload'));
        allow read: if hasRole('pestoun') && isSameTenant(tenantId)
                       && resource.data.ownerId == request.auth.uid;
        allow write: if hasRole('pestoun') && isSameTenant(tenantId)
                        && resource.data.ownerId == request.auth.uid
                        && hasCap('docs.upload');
        allow read: if hasRole('dite') && isSameTenant(tenantId)
                       && resource.data.ownerId == request.auth.uid;
      }

      match /timeline/{entryId} {
        allow read: if isSameTenant(tenantId) && (
          isSuperadminLegacy() || hasRole('vedeni') || hasRole('ko') || hasRole('asistent') ||
          (hasRole('pestoun') && resource.data.scope == 'pestoun' && resource.data.ownerId == request.auth.uid)
        );
        allow create: if isSameTenant(tenantId) && hasCap('notes.add');
        allow update, delete: if false;
      }

      match /documents/{docId} {
        allow read: if isSameTenant(tenantId) && (
          isSuperadminLegacy() || hasRole('vedeni') || hasRole('ko') || hasRole('asistent') ||
          (hasRole('pestoun') && resource.data.ownerId == request.auth.uid)
        );
        allow create: if isSameTenant(tenantId) && hasCap('docs.upload')
                         && request.resource.data.keys().hasAll(['name','tenantId','createdAt']);
        allow update: if isSameTenant(tenantId) && (
          hasCap('contacts.edit') ||
          (hasRole('pestoun') && resource.data.ownerId == request.auth.uid && hasCap('docs.upload'))
        );
        allow delete: if isSuperadminLegacy();
      }

      match /vykazy/{vykazId} {
        allow read: if isSameTenant(tenantId) && (
          isSuperadminLegacy() || hasRole('vedeni') || hasRole('ko') ||
          (hasRole('externista') && resource.data.externistaId == request.auth.uid)
        );
        allow create: if hasRole('externista') && isSameTenant(tenantId)
                         && request.resource.data.externistaId == request.auth.uid;
        allow update: if (hasRole('externista') && resource.data.externistaId == request.auth.uid
                          && resource.data.stav == 'cekajici')
                      || hasRole('vedeni') || isSuperadminLegacy();
        allow delete: if isSuperadminLegacy();
      }

      match /institutions/{instId} {
        allow read: if isSameTenant(tenantId);
        allow write: if isSuperadminLegacy() || (hasRole('vedeni') && isSameTenant(tenantId));
      }

      match /card_templates/{tplId} {
        allow read: if isSameTenant(tenantId);
        allow write: if isSuperadminLegacy();
      }

      match /audit_log/{logId} {
        allow read:   if isSuperadminLegacy() || hasRole('vedeni');
        allow create: if isAuthenticatedLegacy() && isSameTenant(tenantId)
                         && request.resource.data.severity == 'critical';
        allow update, delete: if false;
      }
    }

    match /global_templates/{tplId} {
      allow read: if isAuthenticatedLegacy();
      allow write: if isSuperadminLegacy();
    }

    // ── Catch-all: vše ostatní zakázat ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
