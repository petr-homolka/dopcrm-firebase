# Firebase konfigurace — zkopírujte do .env.local a doplňte reálné hodnoty
# Hodnoty najdete v Firebase Console → Project Settings → Your apps → SDK setup and configuration

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# Volitelné — Firebase Analytics (nechte prázdné pokud nepoužíváte)
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Volitelné — AI proxy endpoint pro lokální testování Vertex AI
# Prázdné = app použije mock AI (funguje bez backendu)
VITE_AI_PROXY_URL=

# Volitelné — jen pro `npm run seed` / `npm run seed:wipe` (scripts/dev-seed.mjs)
# Přihlašovací údaje VAŠEHO superadmin účtu — skript se pod nimi přihlásí,
# aby mu firestore.rules povolily zápis/mazání. NIKDY se necommitují (.env.local
# je v .gitignore) a skript sám nikdy není součástí appky nasazené na web.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
